<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobis — Market Update Generator</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --green: #A8C53A; --dark: #1A1A1A; --white: #FFFFFF;
  --surface: #F7F7F5; --border: #E5E5E2; --text: #1A1A1A;
  --muted: #888884; --danger-bg: #FEF2F2; --danger: #B91C1C;
  --success-bg: #F0F7E0; --success: #3B6D11;
}
body { font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif; background: var(--surface); color: var(--text); min-height: 100vh; }

.header { background: var(--dark); padding: 0 2.5rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
.logo { font-size: 20px; font-weight: 700; color: var(--white); letter-spacing: -0.3px; }
.logo span { color: var(--green); }
.logo-tag { font-size: 11px; color: #666; margin-left: 10px; letter-spacing: 0.06em; text-transform: uppercase; }
.period-badge { background: rgba(168,197,58,0.15); color: var(--green); border: 1px solid rgba(168,197,58,0.3); padding: 4px 12px; border-radius: 99px; font-size: 12px; font-weight: 600; letter-spacing: 0.04em; }

.steps { background: var(--white); border-bottom: 1px solid var(--border); display: flex; padding: 0 2.5rem; overflow-x: auto; }
.step { padding: 14px 0; margin-right: 2.5rem; font-size: 12px; font-weight: 500; color: var(--muted); border-bottom: 2px solid transparent; display: flex; align-items: center; gap: 7px; white-space: nowrap; transition: all 0.15s; }
.step.active { color: var(--dark); border-bottom-color: var(--dark); }
.step.done { color: var(--green); border-bottom-color: var(--green); }
.step-num { width: 20px; height: 20px; border-radius: 50%; background: var(--muted); color: var(--white); font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.step.active .step-num { background: var(--dark); }
.step.done .step-num { background: var(--green); }

.main { max-width: 1000px; margin: 0 auto; padding: 2.5rem 1.5rem; }

.card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 1.75rem; margin-bottom: 1.25rem; }
.card-title { font-size: 16px; font-weight: 600; color: var(--dark); margin-bottom: 4px; }
.card-sub { font-size: 13px; color: var(--muted); margin-bottom: 1.25rem; line-height: 1.5; }

.field-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 1.25rem; }
label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; display: block; margin-bottom: 5px; }
select, input[type=text] { width: 100%; padding: 9px 12px; border: 1px solid var(--border); border-radius: 8px; font-size: 14px; background: var(--white); color: var(--text); outline: none; transition: border-color 0.15s; }
select:focus, input:focus { border-color: #999; }

.btn { padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.15s; text-decoration: none; }
.btn-dark { background: var(--dark); color: var(--white); }
.btn-dark:hover:not(:disabled) { background: #333; }
.btn-dark:disabled { opacity: 0.35; cursor: not-allowed; }
.btn-outline { background: transparent; color: var(--dark); border: 1px solid var(--border); }
.btn-outline:hover { background: var(--surface); }
.btn-green { background: var(--green); color: var(--dark); font-weight: 700; }
.btn-green:hover { filter: brightness(1.06); }

.status-bar { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px 16px; font-size: 13px; color: var(--muted); display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; }
.status-bar.error { background: var(--danger-bg); border-color: #FECACA; color: var(--danger); }
.status-bar.success { background: var(--success-bg); border-color: #C6E89A; color: var(--success); }
.spinner { width: 16px; height: 16px; border: 2px solid #DDD; border-top-color: var(--dark); border-radius: 50%; animation: spin 0.7s linear infinite; flex-shrink: 0; }
@keyframes spin { to { transform: rotate(360deg); } }

.deals-header { display: grid; grid-template-columns: 2fr 1.5fr 1.2fr 0.9fr auto; gap: 10px; padding: 6px 12px; font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
.deal-row { display: grid; grid-template-columns: 2fr 1.5fr 1.2fr 0.9fr auto; gap: 10px; padding: 10px 12px; border-radius: 8px; align-items: center; border-bottom: 1px solid var(--border); transition: background 0.1s; }
.deal-row:last-child { border-bottom: none; }
.deal-row:hover { background: var(--surface); }
.deal-name { font-size: 13px; font-weight: 600; color: var(--dark); }
.deal-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
.deal-acquirer { font-size: 13px; color: var(--dark); }
.seg-badge { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 99px; border: 1px solid var(--border); color: var(--muted); background: var(--surface); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; }
.dutch-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--green); margin-right: 5px; vertical-align: middle; flex-shrink: 0; }
.type-badge { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 99px; }
.type-Acquired  { background: #EFF6FF; color: #1E40AF; border: 1px solid #BFDBFE; }
.type-Invested  { background: #F0FDF4; color: #166534; border: 1px solid #BBF7D0; }
.type-Merged    { background: #FFF7ED; color: #92400E; border: 1px solid #FDE68A; }
.type-Recapitalised { background: #FAF5FF; color: #6B21A8; border: 1px solid #E9D5FF; }

.add-btn { padding: 5px 14px; border-radius: 6px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid var(--border); background: var(--white); color: var(--dark); white-space: nowrap; transition: all 0.1s; }
.add-btn:hover { background: var(--dark); color: var(--white); border-color: var(--dark); }
.add-btn.added { background: var(--success-bg); border-color: var(--green); color: var(--success); cursor: default; }

.sel-row { display: grid; grid-template-columns: 1fr 1fr 1.2fr 0.8fr 28px; gap: 8px; margin-bottom: 8px; align-items: center; }
.sel-row input, .sel-row select { font-size: 12px; padding: 7px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--white); color: var(--text); width: 100%; }
.remove-btn { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 18px; line-height: 1; }
.remove-btn:hover { color: var(--danger); }

.stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; padding: 1.5rem; background: var(--white); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 1.25rem; }
.stat-card { text-align: center; }
.stat-val { font-size: 36px; font-weight: 700; color: var(--dark); line-height: 1; }
.stat-val.green { color: #3B7A00; }
.stat-val.red { color: var(--danger); }
.stat-lbl { font-size: 11px; color: var(--muted); margin-top: 5px; }

.preview { background: var(--surface); border-radius: 8px; border: 1px solid var(--border); padding: 1rem 1.25rem; font-size: 13px; color: #444; line-height: 1.75; white-space: pre-wrap; min-height: 60px; }
.preview.streaming { border-color: var(--green); }
.tag-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.tag { font-size: 11px; padding: 2px 8px; border-radius: 99px; font-weight: 600; }
.tag-ai { background: #EFF6FF; color: #1E40AF; }

.sources { display: flex; flex-wrap: wrap; gap: 6px; }
.source-chip { font-size: 11px; padding: 3px 10px; border-radius: 99px; border: 1px solid var(--border); color: var(--muted); }

.row-between { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.add-link { background: none; border: none; font-size: 13px; color: var(--muted); text-decoration: underline; cursor: pointer; padding: 0; }
.add-link:hover { color: var(--dark); }
.section-divider { height: 1px; background: var(--border); margin: 1.5rem 0; }
.legend { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); margin: 10px 0; }

.download-card { background: var(--dark); border-radius: 12px; padding: 3rem 2rem; text-align: center; color: var(--white); }
.download-card h2 { font-size: 24px; margin-bottom: 8px; }
.download-card p { font-size: 13px; color: #888; margin-bottom: 1.75rem; }

.hidden { display: none !important; }
</style>
</head>
<body>

<div class="header">
  <div style="display:flex;align-items:center">
    <div class="logo">mob<span>i</span>s.</div>
    <span class="logo-tag">market update generator</span>
  </div>
  <span class="period-badge" id="period-badge">Select period</span>
</div>

<div class="steps">
  <div class="step active" id="tab1"><div class="step-num">1</div> Configure</div>
  <div class="step"        id="tab2"><div class="step-num">2</div> Review deals</div>
  <div class="step"        id="tab3"><div class="step-num">3</div> Generate</div>
  <div class="step"        id="tab4"><div class="step-num">4</div> Download</div>
</div>

<div class="main">

  <!-- STEP 1 -->
  <div id="step1">
    <div class="card">
      <div class="card-title">Report period</div>
      <div class="card-sub">Set the quarter and hit Scan. Claude will search all sources, find every deal, and automatically count transactions for this period and the same period last year — no manual input needed.</div>
      <div class="field-row">
        <div><label>Quarter</label>
          <select id="quarter"><option>Q1</option><option>Q2</option><option>Q3</option><option>Q4</option></select>
        </div>
        <div><label>Year</label>
          <select id="year">
            <option>2023</option><option>2024</option><option selected>2025</option><option>2026</option>
          </select>
        </div>
        <div><label>Geography focus</label>
          <select id="geo">
            <option>Europe &amp; North America</option>
            <option selected>Netherlands (focus)</option>
            <option>Benelux</option>
          </select>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Sources</div>
      <div class="card-sub" style="margin-bottom:10px">All 11 sources scanned in parallel — current quarter and same quarter last year.</div>
      <div class="sources">
        <span class="source-chip">bike-eu.com</span><span class="source-chip">cyclingindustry.news</span>
        <span class="source-chip">nieuwsfiets.nu</span><span class="source-chip">bicycleretailer.com</span>
        <span class="source-chip">velobiz.de</span><span class="source-chip">bikebiz.com</span>
        <span class="source-chip">micromobilitybiz.com</span><span class="source-chip">zagdaily.com</span>
        <span class="source-chip">tech.eu</span><span class="source-chip">siliconcanals.com</span>
        <span class="source-chip">road.cc</span>
      </div>
    </div>

    <div id="scan-status"></div>

    <button class="btn btn-dark" id="scan-btn" onclick="startScan()">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
      Scan for deals
    </button>
  </div>

  <!-- STEP 2 -->
  <div id="step2" class="hidden">
    <div class="card">
      <div class="row-between">
        <div>
          <div class="card-title">Found transactions <span id="found-count" style="font-size:13px;font-weight:400;color:var(--muted)"></span></div>
          <div class="card-sub" style="margin-bottom:0">Click <strong>Add</strong> on deals to feature. <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--green);vertical-align:middle"></span> = Dutch / Benelux deal.</div>
        </div>
        <button class="btn btn-outline" style="font-size:12px;padding:6px 14px" onclick="addAllDeals()">Add all</button>
      </div>
      <div class="deals-header" style="margin-top:14px">
        <div>Target</div><div>Acquirer / investor</div><div>Segment</div><div>Type</div><div></div>
      </div>
      <div id="found-list"></div>
    </div>

    <div class="section-divider"></div>

    <div class="card">
      <div class="row-between">
        <div class="card-title">Your selection <span id="sel-count" style="font-size:13px;font-weight:400;color:var(--muted)">(0 deals)</span></div>
        <button class="add-link" onclick="addManual()">+ add manually</button>
      </div>
      <div id="sel-empty" style="font-size:13px;color:var(--muted);padding:10px 0">No deals added yet — click Add above.</div>
      <div id="sel-header" class="hidden deals-header" style="grid-template-columns:1fr 1fr 1.2fr 0.8fr 28px">
        <div>Target</div><div>Acquirer / investor</div><div>Segment</div><div>Type</div><div></div>
      </div>
      <div id="sel-list"></div>
    </div>

    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <button class="btn btn-dark" onclick="goGenerate()">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        Generate commentary
      </button>
      <button class="btn btn-outline" onclick="setStep(1)">← Back</button>
    </div>
  </div>

  <!-- STEP 3 -->
  <div id="step3" class="hidden">
    <div id="stats-display" class="stats-row hidden">
      <div class="stat-card">
        <div class="stat-val" id="stat-current">—</div>
        <div class="stat-lbl" id="stat-current-lbl">transactions this period</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" id="stat-prev">—</div>
        <div class="stat-lbl" id="stat-prev-lbl">same period last year</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" id="stat-change">—</div>
        <div class="stat-lbl">year-on-year change</div>
      </div>
    </div>

    <div id="gen-status"></div>

    <div id="gen-output" class="hidden">
      <div class="card">
        <div class="tag-row"><span class="card-title">Key takeaways</span><span class="tag tag-ai">AI generated</span></div>
        <div class="preview" id="out-takeaways"></div>
      </div>
      <div class="card">
        <div class="tag-row"><span class="card-title">Sector news highlights</span><span class="tag tag-ai">AI generated</span></div>
        <div class="preview" id="out-news"></div>
      </div>
      <div class="card">
        <div class="tag-row"><span class="card-title">Deal commentary</span><span class="tag tag-ai">AI generated</span></div>
        <div class="preview" id="out-deal"></div>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-dark" id="build-btn" onclick="buildDeck()">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
          Build PowerPoint
        </button>
        <button class="btn btn-outline" onclick="setStep(2)">← Back</button>
      </div>
    </div>
  </div>

  <!-- STEP 4 -->
  <div id="step4" class="hidden">
    <div class="download-card">
      <div style="font-size:48px;margin-bottom:16px">📊</div>
      <h2>Your deck is ready</h2>
      <p id="deck-subtitle">Mobis Market Update</p>
      <a id="download-link" href="#" class="btn btn-green" style="font-size:15px;padding:14px 32px;display:inline-flex">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download .pptx
      </a>
      <div style="margin-top:1.5rem">
        <button class="btn btn-outline" style="background:transparent;border-color:#444;color:#999;margin:0 auto" onclick="resetAll()">Start new update</button>
      </div>
    </div>
  </div>

</div>

<script>
const SEGMENTS = ['Bike Manufacturers','Service Providers','Retail / Distribution','PAC','Bike Leasing'];
const DEAL_TYPES = ['Acquired','Invested in','Merged with','Recapitalised'];

let S = { found:[], selected:[], added:new Set(), scan:{}, content:{} };

function setStep(n) {
  [1,2,3,4].forEach(i => {
    document.getElementById('tab'+i).className = 'step'+(i<n?' done':i===n?' active':'');
    document.getElementById('step'+i).classList.toggle('hidden', i!==n);
  });
  window.scrollTo(0,0);
}

async function startScan() {
  const q = document.getElementById('quarter').value;
  const y = document.getElementById('year').value;
  document.getElementById('period-badge').textContent = `${q} ${y}`;
  document.getElementById('scan-btn').disabled = true;

  const statusEl = document.getElementById('scan-status');
  statusEl.innerHTML = '<div class="status-bar"><div class="spinner"></div><span id="scan-msg">Connecting to sources…</span></div>';

  try {
    const resp = await fetch('/api/scan', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ quarter:q, year:y })
    });

    const reader = resp.body.getReader();
    const dec = new TextDecoder();
    let buf = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buf += dec.decode(value, { stream:true });
      const lines = buf.split('\n'); buf = lines.pop();
      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const evt = JSON.parse(line.slice(6));
        if (evt.type === 'status') document.getElementById('scan-msg').textContent = evt.msg;
        if (evt.type === 'result') {
          S.scan = evt; S.found = evt.currentDeals;
          statusEl.innerHTML = `<div class="status-bar success">✓ Found ${evt.currentDeals.length} deals in ${q} ${y} and ${evt.prevDeals.length} in ${q} ${evt.prevYear}</div>`;
          document.getElementById('scan-btn').disabled = false;
          renderFound(); setStep(2);
        }
        if (evt.type === 'error') {
          statusEl.innerHTML = `<div class="status-bar error">⚠ ${evt.msg}</div>`;
          document.getElementById('scan-btn').disabled = false;
        }
      }
    }
  } catch(e) {
    document.getElementById('scan-status').innerHTML = `<div class="status-bar error">⚠ ${e.message}</div>`;
    document.getElementById('scan-btn').disabled = false;
  }
}

function renderFound() {
  const c = document.getElementById('found-list');
  document.getElementById('found-count').textContent = `(${S.found.length} deals found)`;
  c.innerHTML = '';
  if (!S.found.length) {
    c.innerHTML = '<div style="font-size:13px;color:var(--muted);padding:12px 0">No deals found automatically — add them manually.</div>';
    return;
  }
  S.found.forEach((d, i) => {
    const typeKey = (d.type||'').split(' ')[0];
    const row = document.createElement('div');
    row.className = 'deal-row';
    row.innerHTML = `
      <div>
        ${d.dutch ? '<span class="dutch-dot" title="Dutch / Benelux"></span>' : ''}
        <span class="deal-name">${d.target||'?'}</span>
        ${d.description ? `<div class="deal-sub">${d.description.slice(0,90)}${d.description.length>90?'…':''}</div>` : ''}
        ${d.amount ? `<div class="deal-sub" style="color:var(--success);font-weight:600">${d.amount}</div>` : ''}
      </div>
      <div class="deal-acquirer">${d.acquirer||'?'}</div>
      <div><span class="seg-badge">${(d.segment||'').replace(' / ','/')}</span></div>
      <div><span class="type-badge type-${typeKey}">${d.type||''}</span></div>
      <button class="add-btn" id="ab-${i}" onclick="addDeal(${i})">Add</button>`;
    c.appendChild(row);
  });
}

function addDeal(i) {
  if (S.added.has(i)) return;
  S.added.add(i);
  const d = S.found[i];
  S.selected.push({ id:Date.now()+Math.random(), target:d.target||'', investor:d.acquirer||'', segment:d.segment||'Service Providers', type:d.type||'Invested in' });
  const btn = document.getElementById('ab-'+i);
  if (btn) { btn.textContent='Added ✓'; btn.className='add-btn added'; }
  renderSelected();
}

function addAllDeals() { S.found.forEach((_,i)=>{ if(!S.added.has(i)) addDeal(i); }); }
function addManual() { S.selected.push({ id:Date.now()+Math.random(), target:'', investor:'', segment:'Service Providers', type:'Invested in' }); renderSelected(); }
function updSel(id,f,v) { const d=S.selected.find(x=>x.id===id); if(d) d[f]=v; }
function remSel(id) { S.selected=S.selected.filter(x=>x.id!==id); renderSelected(); }

function renderSelected() {
  const list=document.getElementById('sel-list');
  const hdr=document.getElementById('sel-header');
  const empty=document.getElementById('sel-empty');
  document.getElementById('sel-count').textContent=`(${S.selected.length} deal${S.selected.length!==1?'s':''})`;
  if (!S.selected.length) { list.innerHTML=''; hdr.classList.add('hidden'); empty.classList.remove('hidden'); return; }
  empty.classList.add('hidden'); hdr.classList.remove('hidden');
  list.innerHTML='';
  S.selected.forEach(d => {
    const row=document.createElement('div'); row.className='sel-row';
    row.innerHTML=`
      <input value="${d.target}" placeholder="Target" oninput="updSel(${d.id},'target',this.value)"/>
      <input value="${d.investor}" placeholder="Acquirer / investor" oninput="updSel(${d.id},'investor',this.value)"/>
      <select onchange="updSel(${d.id},'segment',this.value)">${SEGMENTS.map(s=>`<option${s===d.segment?' selected':''}>${s}</option>`).join('')}</select>
      <select onchange="updSel(${d.id},'type',this.value)">${DEAL_TYPES.map(t=>`<option${t===d.type?' selected':''}>${t}</option>`).join('')}</select>
      <button class="remove-btn" onclick="remSel(${d.id})">×</button>`;
    list.appendChild(row);
  });
}

async function goGenerate() {
  const sd = S.scan;
  setStep(3);

  // Stats
  const curr=sd.currentCount||0, prev=sd.prevCount||0;
  const change=curr-prev, pct=prev?Math.round(change/prev*100):0;
  document.getElementById('stat-current').textContent=curr;
  document.getElementById('stat-current-lbl').textContent=`transactions ${sd.quarter} ${sd.year}`;
  document.getElementById('stat-prev').textContent=prev;
  document.getElementById('stat-prev-lbl').textContent=`transactions ${sd.quarter} ${sd.prevYear}`;
  const ce=document.getElementById('stat-change');
  ce.textContent=(change>0?'+':'')+change+' ('+(pct>0?'+':'')+pct+'%)';
  ce.className='stat-val '+(change>0?'green':change<0?'red':'');
  document.getElementById('stats-display').classList.remove('hidden');

  const statusEl=document.getElementById('gen-status');
  statusEl.innerHTML='<div class="status-bar"><div class="spinner"></div><span>Generating Mobis commentary…</span></div>';
  document.getElementById('gen-output').classList.add('hidden');
  ['out-takeaways','out-news','out-deal'].forEach(id=>{ document.getElementById(id).textContent=''; document.getElementById(id).classList.remove('streaming'); });

  try {
    const resp=await fetch('/api/generate',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ quarter:sd.quarter, year:sd.year, selectedDeals:S.selected.filter(d=>d.target), currentCount:curr, prevCount:prev })
    });

    const reader=resp.body.getReader(); const dec=new TextDecoder(); let buf='', full='';
    while(true){
      const{done,value}=await reader.read(); if(done) break;
      buf+=dec.decode(value,{stream:true});
      const lines=buf.split('\n'); buf=lines.pop();
      for(const line of lines){
        if(!line.startsWith('data: ')) continue;
        const evt=JSON.parse(line.slice(6));
        if(evt.type==='chunk'){ full+=evt.text; updatePreviews(full); document.getElementById('gen-output').classList.remove('hidden'); }
        if(evt.type==='done'){
          S.content=evt; statusEl.innerHTML='';
          document.getElementById('out-takeaways').textContent=evt.takeaways||'';
          document.getElementById('out-news').textContent=evt.sectorNews||'';
          document.getElementById('out-deal').textContent=evt.dealComm||'';
          ['out-takeaways','out-news','out-deal'].forEach(id=>document.getElementById(id).classList.remove('streaming'));
        }
        if(evt.type==='error') statusEl.innerHTML=`<div class="status-bar error">⚠ ${evt.msg}</div>`;
      }
    }
  } catch(e){ document.getElementById('gen-status').innerHTML=`<div class="status-bar error">⚠ ${e.message}</div>`; }
}

function updatePreviews(text) {
  const extract=(t,s,e)=>{const i=t.indexOf(s);if(i===-1)return '';const a=t.slice(i+s.length);if(!e)return a;const j=a.indexOf(e);return j===-1?a:a.slice(0,j);};
  const ta=extract(text,'TAKEAWAYS:','---'), sn=extract(text,'SECTOR_NEWS:','---'), dc=extract(text,'DEAL_COMMENTARY:',null);
  if(ta){document.getElementById('out-takeaways').textContent=ta;document.getElementById('out-takeaways').classList.add('streaming');}
  if(sn){document.getElementById('out-news').textContent=sn;document.getElementById('out-news').classList.add('streaming');}
  if(dc){document.getElementById('out-deal').textContent=dc;document.getElementById('out-deal').classList.add('streaming');}
}

async function buildDeck() {
  const btn=document.getElementById('build-btn');
  btn.disabled=true; btn.innerHTML='Building…';
  const sd=S.scan; const gc=S.content;
  try {
    const resp=await fetch('/api/build-pptx',{
      method:'POST', headers:{'Content-Type':'application/json'},
      body:JSON.stringify({ quarter:sd.quarter, year:sd.year, prevYear:sd.prevYear, selectedDeals:S.selected.filter(d=>d.target), currentCount:sd.currentCount, prevCount:sd.prevCount, takeaways:gc.takeaways, sectorNews:gc.sectorNews, dealComm:gc.dealComm })
    });
    if(!resp.ok) throw new Error(await resp.text());
    const blob=await resp.blob();
    const url=URL.createObjectURL(blob);
    document.getElementById('download-link').href=url;
    document.getElementById('download-link').download=`Mobis_Market_Update_${sd.quarter}_${sd.year}.pptx`;
    document.getElementById('deck-subtitle').textContent=`Mobis Market Update — ${sd.quarter} ${sd.year}`;
    setStep(4);
  } catch(e){ alert('Build failed: '+e.message); btn.disabled=false; btn.innerHTML='Build PowerPoint'; }
}

function resetAll() {
  S={ found:[], selected:[], added:new Set(), scan:{}, content:{} };
  document.getElementById('scan-btn').disabled=false;
  document.getElementById('scan-status').innerHTML='';
  document.getElementById('period-badge').textContent='Select period';
  setStep(1);
}
</script>
</body>
</html>
